{
  "name": "umbra",
  "productName": "Umbra",
  "version": "0.2.0",
  "description": "Umbra — Arriba como abajo. Chat with shadows.",
  "author": "Umbra Local",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:server": "node --watch server/index.js",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:3030 tcp:5173 && node scripts/run-electron.cjs .",
    "build": "vite build",
    "build:desktop": "npm run build && electron-builder --win nsis --publish never",
    "pack:desktop": "npm run build && electron-builder --dir --publish never",
    "setup:supabase": "node scripts/bootstrap-supabase.js",
    "start": "node server/index.js",
    "start:desktop": "node scripts/run-electron.cjs ."
  },
  "dependencies": {
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@supabase/supabase-js": "^2.49.4",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "lucide-react": "^1.7.0",
    "marked": "^15.0.7",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "vite": "^6.2.6",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.umbra.chat",
    "productName": "Umbra",
    "icon": "build/icon.png",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "build/icon.png",
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Umbra Auth",
        "schemes": [
          "umbra"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
